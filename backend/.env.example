# App
APP_ENV=development
SECRET_KEY=change-me-in-production

# LLM
OPENAI_API_KEY=sk-...
OPENAI_MODEL_CHEAP=gpt-4o-mini
OPENAI_MODEL_HEAVY=gpt-4o

# Redis
REDIS_URL=redis://localhost:6379

# SQLite (MVP)
DATABASE_URL=sqlite+aiosqlite:///./data/delegates.db

# MS Graph (email + calendar)
MSGRAPH_TENANT_ID=
MSGRAPH_CLIENT_ID=
MSGRAPH_CLIENT_SECRET=
MSGRAPH_USER_EMAIL=

# Delegate polling
EMAIL_POLL_INTERVAL_SECONDS=900

# CORS
FRONTEND_URL=http://localhost:3000

# Allowlist — comma-separated identifiers (emails, phone numbers, etc.) permitted to trigger delegate actions
ALLOWLIST=

# Google OAuth (Calendar)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Company enrichment (optional)
APOLLO_API_KEY=

# Calendar
CALENDAR_PREBLOCK_THRESHOLD=0.80

# Notification channels (all optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_BOT_TOKEN=
SLACK_DEFAULT_CHANNEL=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_DEFAULT_TO=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
SMS_DEFAULT_TO=

# Voice — Rose-inspired STT (Groq) + TTS (ElevenLabs)
GROQ_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
TTS_CACHE_TTL_SECONDS=86400
STT_MAX_AUDIO_MB=25
