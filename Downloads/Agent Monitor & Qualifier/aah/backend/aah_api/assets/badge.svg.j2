<svg xmlns="http://www.w3.org/2000/svg" width="240" height="20" role="img" aria-label="AAH: {{ status_text }}">
  <linearGradient id="s" x2="0" y2="100%"><stop offset="0" stop-opacity=".1" stop-color="#EEE"/><stop offset="1" stop-opacity=".1"/></linearGradient>
  <mask id="m"><rect width="240" height="20" rx="3" fill="#fff"/></mask>
  <g mask="url(#m)">
    <rect width="70" height="20" fill="#555"/>
    <rect x="70" width="170" height="20" fill="{{ color }}"/>
    <rect width="240" height="20" fill="url(#s)"/>
  </g>
  <g fill="#fff" text-anchor="middle" font-family="DejaVu Sans,Verdana,Geneva,sans-serif" font-size="11">
    <text x="35" y="14">AAH</text>
    <text x="155" y="14">{{ status_text }} • {{ score }}</text>
  </g>
</svg>
