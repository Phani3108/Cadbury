{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["agent", "environment", "tests"],
  "properties": {
    "agent": {"type": "string"},
    "environment": {"type": "string", "enum": ["dev", "staging", "prod", "testing"]},
    "policies": {
      "type": "object",
      "properties": {
        "pii_leakage": {"type": "string", "enum": ["block", "warn", "ignore"]},
        "tool_schema_strict": {"type": "boolean"}
      }
    },
    "budgets": {
      "type": "object",
      "properties": {
        "max_latency_ms": {"type": "integer", "minimum": 1},
        "max_cost_usd": {"type": "number", "minimum": 0}
      }
    },
    "determinism": {
      "type": "object",
      "properties": {
        "samples": { "type": "integer", "minimum": 1, "maximum": 200 },
        "concurrency": { "type": "integer", "minimum": 1, "maximum": 64 },
        "thresholds": {
          "type": "object",
          "properties": {
            "min_determinism_pct": { "type": "integer", "minimum": 0, "maximum": 100 },
            "max_p95_latency_ms": { "type": "integer", "minimum": 1 },
            "max_p95_cost_usd": { "type": "number", "minimum": 0 },
            "max_cv_latency": { "type": "number", "minimum": 0 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "tests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "prompt", "expects"],
        "properties": {
          "id": {"type": "string"},
          "prompt": {"type": "string"},
          "context": {"type": "object"},
          "expects": {
            "type": "object",
            "properties": {
              "contains": {"type": "array", "items": {"type": "string"}},
              "not_contains": {"type": "array", "items": {"type": "string"}},
              "blocked": {"type": "boolean"},
              "tool_calls": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["name"],
                  "properties": {
                    "name": {"type": "string"},
                    "schema_ok": {"type": "boolean"}
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
