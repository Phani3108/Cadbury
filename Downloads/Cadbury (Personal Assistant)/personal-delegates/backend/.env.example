# App
APP_ENV=development
SECRET_KEY=change-me-in-production

# LLM
OPENAI_API_KEY=sk-...
OPENAI_MODEL_CHEAP=gpt-4o-mini
OPENAI_MODEL_HEAVY=gpt-4o

# Redis
REDIS_URL=redis://localhost:6379

# SQLite (MVP)
