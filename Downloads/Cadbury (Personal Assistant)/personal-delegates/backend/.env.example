MSGRAPH_CLIENT_ID=
MSGRAPH_CLIENT_SECRET=
MSGRAPH_USER_EMAIL=

# Delegate polling
EMAIL_POLL_INTERVAL_SECONDS=900

# CORS
FRONTEND_URL=http://localhost:3000
