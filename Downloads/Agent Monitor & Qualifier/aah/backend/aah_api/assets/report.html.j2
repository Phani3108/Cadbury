<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>AAH Trust Report — {{ summary.run_id }}</title>
  <style>
    body{font-family:system-ui,-apple-system,Segoe UI,Roboto,sans-serif;margin:24px;line-height:1.45}
    .score{font-size:48px;font-weight:800}
    .grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
    .card{border:1px solid #ddd;border-radius:12px;padding:16px}
    code{background:#f6f8fa;border-radius:6px;padding:2px 6px}
    .pass{color:#0a7a3e}.fail{color:#b00020}
    table{border-collapse:collapse;width:100%} th,td{border:1px solid #eee;padding:8px;text-align:left}
  </style>
</head>
<body>
  <h1>AAH Trust Report</h1>
  <p><strong>Run:</strong> {{ summary.run_id }} • <strong>Agent:</strong> {{ summary.agent }} ({{ summary.environment }})</p>

  <div class="grid">
    <div class="card"><div>Overall Score</div><div class="score">{{ summary.scores.overall }}</div></div>
    <div class="card"><div>Functional</div><div class="score">{{ summary.scores.functional }}</div></div>
    <div class="card"><div>Safety</div><div class="score">{{ summary.scores.safety }}</div></div>
  </div>

  <div class="card">
    <div>Certification</div>
    <div class="score" style="font-size:32px;">
      {{ 'CERTIFIED ' ~ summary.cert.version if summary.certified else 'NOT CERTIFIED' }}
    </div>
    {% if summary.cert and summary.cert.reasons and (not summary.certified) %}
      <ul>
        {% for r in summary.cert.reasons %}<li>{{ r }}</li>{% endfor %}
      </ul>
    {% endif %}
    <div style="margin-top:8px;">
      <img alt="badge" src="/runs/{{ summary.run_id }}/badge.svg" />
    </div>
  </div>

  <h2>Packs</h2>
  {% for pack, pack_results in results.items() %}
  <div class="card">
    <h3>{{ pack|capitalize }} ({{ pack_results|length }} tests)</h3>
    <table>
  <thead><tr><th>Test</th><th>Pass</th><th>Latency (ms)</th><th>Cost (USD)</th>{% if pack == 'grounding' %}<th>Evidence</th>{% endif %}{% if pack == 'determinism' %}<th>Stats</th>{% endif %}<th>Key Assertions</th></tr></thead>
      <tbody>
      {% for r in pack_results %}
        <tr>
          <td><code>{{ r.id }}</code></td>
          <td class="{{ 'pass' if r.passed else 'fail' }}">{{ 'PASS' if r.passed else 'FAIL' }}</td>
          <td>{{ r.latency_ms }}</td>
          <td>{{ "%.5f"|format(r.cost_usd) }}</td>
          {% if pack == 'grounding' %}
          <td>
            {% set ev = r.meta and r.meta.evidence or [] %}
            {% if ev|length == 0 %}-{% else %}
              <details>
                <summary>{{ ev|length }} passages</summary>
                <ol>
                  {% for h in ev %}
                    <li><code>{{ h.source_id }}</code> • {{ h.title }} • {{ "%.3f"|format(h.score) }} • <span class="small">{{ h.file }} #{{ h.chunk }}</span></li>
                  {% endfor %}
                </ol>
              </details>
            {% endif %}
          </td>
          {% endif %}
          {% if pack == 'determinism' %}
          <td>
            {% if r.meta and r.meta.latency_ms %}
              det={{ r.meta.determinism_pct }}%
              · p50/p95/p99={{ r.meta.latency_ms.p50 }}/{{ r.meta.latency_ms.p95 }}/{{ r.meta.latency_ms.p99 }}ms
              · cv={{ r.meta.latency_ms.cv }}
              · pass={{ r.meta.pass_rate_pct }}%
            {% else %}-{% endif %}
          </td>
          {% endif %}
          <td>
            {% for a in r.assertions %}
              <div class="pass" if a.passed else "fail" >{{ a.type }} — {{ 'OK' if a.passed else 'FAIL' }}</div>
            {% endfor %}
          </td>
        </tr>
      {% endfor %}
      </tbody>
    </table>
  </div>
  {% endfor %}

  <h2>Policy & Schema</h2>
  <p>Truth Policy Hash: <code>{{ summary.policy_hash }}</code><br/>
     Spec Schema Hash: <code>{{ summary.spec_schema_hash }}</code></p>

  <footer><small>Generated by AAH • This report honors the Truth Policy and Definition of Done.</small></footer>
</body>
</html>
